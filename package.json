{
  "name": "l402-kit",
  "version": "0.5.0",
  "description": "Add Bitcoin Lightning pay-per-call to any API in 3 lines. L402 protocol, zero config, 0.3% fee. npm install l402-kit",
  "homepage": "https://shinydapps-bd9fa40b.mintlify.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShinyDapps/l402-kit"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest --passWithNoTests",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "l402",
    "lightning",
    "bitcoin",
    "http402",
    "micropayments",
    "pay-per-call",
    "breez",
    "macaroon"
  ],
  "author": "Thiago Yoshiaki",
  "license": "MIT",
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.2",
    "express": "^4.21.0",
    "jest": "^29.7.0",
    "sharp": "^0.34.5",
    "supertest": "^7.1.0",
    "ts-jest": "^29.4.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
