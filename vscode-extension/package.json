{
  "name": "shinydapps-l402",
  "displayName": "ShinyDapps ⚡ Lightning Payments",
  "description": "Monitor your Bitcoin Lightning API payments in real-time inside VS Code",
  "version": "0.9.1",
  "publisher": "ShinyDapps",
  "icon": "icon.png",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "keywords": [
    "bitcoin", "btc", "crypto", "cripto", "cryptocurrency", "criptomoeda",
    "blockchain", "web3", "lightning", "lightning-network", "lightning-payment",
    "l402", "bolt11", "satoshi", "sats", "lnurl", "payments", "micropayments",
    "pay-per-call", "api-monetization", "paywall", "blink", "lnbits", "shinydapps",
    "dashboard", "monitoring",
    "ai-agent", "ai-payment", "ai payments", "agent payment", "llm payment",
    "pagamento ia", "agente ia", "pagamento de ia", "agente de ia",
    "pago ia", "agente de inteligencia artificial", "paiement ia", "agent ia",
    "pagamento intelligenza artificiale", "agente intelligenza artificiale",
    "bitcoin italiano", "bitcoin arabo", "bitcoin arabic",
    "بيتكوين", "بي تي سي", "كريبتو", "بلوكتشين", "مدفوعات", "عملة رقمية",
    "وكيل ذكاء اصطناعي", "دفع بالذكاء الاصطناعي",
    "bitcoin", "pagamento bitcoin", "rete lightning", "criptovaluta",
    "moneta digitale", "pagamento automatico", "agente automatico",
    "비트코인", "라이트닝", "암호화폐", "블록체인",
    "比特币", "闪电网络", "加密货币", "区块链", "人工智能支付",
    "ビットコイン", "ライトニング", "暗号通貨", "AIエージェント",
    "bitcoin zahlung", "kryptowährung", "blitzkanal",
    "paiement bitcoin", "cryptomonnaie", "réseau lightning",
    "оплата биткоин", "криптовалюта", "молниеносная сеть"
  ],
  "repository": { "type": "git", "url": "https://github.com/ShinyDapps/l402-kit" },
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "shinydapps.showDashboard",
        "title": "ShinyDapps: Open Payment Dashboard",
        "icon": { "light": "lightning.svg", "dark": "lightning.svg" }
      },
      {
        "command": "shinydapps.configure",
        "title": "ShinyDapps: Configure Lightning Address"
      }
    ],
    "configuration": {
      "title": "ShinyDapps",
      "properties": {
        "shinydapps.lightningAddress": {
          "type": "string",
          "description": "Your Lightning Address (e.g. you@blink.sv)"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shinydapps",
          "title": "ShinyDapps — Lightning Payments",
          "icon": "lightning.svg"
        }
      ]
    },
    "views": {
      "shinydapps": [
        {
          "id": "shinydapps.payments",
          "name": "⚡ Payments",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "shinydapps.configure",
          "when": "view == shinydapps.payments",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.4.0"
  }
}
