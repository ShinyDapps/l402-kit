{
  "name": "shinydapps-l402",
  "displayName": "ShinyDapps Lightning Payments",
  "description": "Real-time Bitcoin Lightning payment dashboard in VS Code. Monitor API micropayments per endpoint, live charts, CSV export. Works with l402-kit (TypeScript, Python, Go, Rust). Zero config.",
  "version": "1.1.4",
  "publisher": "ShinyDapps",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "galleryBanner": {
    "color": "#0D0D0D",
    "theme": "dark"
  },
  "baseImagesUrl": "https://raw.githubusercontent.com/ShinyDapps/l402-kit/main/vscode-extension",
  "keywords": [
    "bitcoin",
    "btc",
    "lightning",
    "lightning-network",
    "lightning-payment",
    "l402",
    "bolt11",
    "satoshi",
    "sats",
    "lnurl",
    "payments",
    "micropayments",
    "pay-per-call",
    "api-monetization",
    "api-billing",
    "api-gateway",
    "paywall",
    "metered-api",
    "blink",
    "lnbits",
    "opennode",
    "shinydapps",
    "dashboard",
    "monitoring",
    "real-time",
    "live-chart",
    "crypto",
    "cryptocurrency",
    "blockchain",
    "web3",
    "defi",
    "defi-payment",
    "layer2",
    "layer-2",
    "wallet",
    "lightning-wallet",
    "crypto-wallet",
    "bitcoin-wallet",
    "ai-agent",
    "ai-payment",
    "llm-payment",
    "agent-payment",
    "autonomous-agent",
    "developer",
    "developer-tools",
    "devtools",
    "sdk",
    "typescript",
    "python",
    "golang",
    "rust",
    "express",
    "fastapi",
    "axum",
    "pagamento",
    "bitcoin pagamento",
    "relampago",
    "criptomoeda",
    "pago bitcoin",
    "red lightning",
    "criptomoneda",
    "paiement bitcoin",
    "cryptomonnaie",
    "réseau lightning",
    "bitcoin zahlung",
    "kryptowährung",
    "blitzkanal",
    "pagamento bitcoin",
    "rete lightning",
    "criptovaluta",
    "比特币",
    "闪电网络",
    "加密货币",
    "区块链",
    "人工智能支付",
    "ビットコイン",
    "ライトニング",
    "暗号通貨",
    "AIエージェント",
    "비트코인",
    "라이트닝",
    "암호화폐",
    "블록체인",
    "оплата биткоин",
    "криптовалюта",
    "молниеносная сеть",
    "بيتكوين",
    "شبكة البرق",
    "كريبتو",
    "بلوكتشين",
    "bitcoin भुगतान",
    "क्रिप्टो",
    "बिटकॉइन"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ShinyDapps/l402-kit"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "shinydapps.showDashboard",
        "title": "ShinyDapps: Open Payment Dashboard",
        "icon": {
          "light": "lightning.svg",
          "dark": "lightning.svg"
        }
      },
      {
        "command": "shinydapps.configure",
        "title": "ShinyDapps: Configure Lightning Address"
      }
    ],
    "configuration": {
      "title": "ShinyDapps",
      "properties": {
        "shinydapps.lightningAddress": {
          "type": "string",
          "description": "Your Lightning Address (e.g. you@blink.sv)"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shinydapps",
          "title": "ShinyDapps - Lightning Payments",
          "icon": "lightning.svg"
        }
      ]
    },
    "views": {
      "shinydapps": [
        {
          "id": "shinydapps.payments",
          "name": "Payments",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "shinydapps.configure",
          "when": "view == shinydapps.payments",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "sharp": "^0.34.5",
    "typescript": "^5.4.0"
  }
}
