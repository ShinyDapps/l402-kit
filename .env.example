# Lightning Provider — choose one
# Option A: Blink (free, no node needed) — dashboard.blink.sv
BLINK_API_KEY=blink_your_api_key_here
BLINK_WALLET_ID=your-wallet-uuid-here

# Option B: OpenNode — app.opennode.com
# OPENNODE_API_KEY=your_key_here
# OPENNODE_TESTMODE=true

# Option C: LNbits self-hosted
# LNBITS_API_KEY=your_invoice_key_here
# LNBITS_URL=https://your-lnbits-instance.com

# Supabase (optional — for payment logging)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# Your Lightning address (receives payments)
OWNER_LIGHTNING_ADDRESS=you@blink.sv

PORT=3000
