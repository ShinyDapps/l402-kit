# l402-kit — Environment Variables
# Copy this to .env and fill in your values. Never commit .env.

# ─── Lightning Provider ────────────────────────────────────────────
# Option A: Blink (free, zero setup) — dashboard.blink.sv
L402KIT_BLINK_API_KEY=blink_your_api_key_here
L402KIT_BLINK_WALLET_ID=your-btc-wallet-uuid-here

# Option B: OpenNode — app.opennode.com
# OPENNODE_API_KEY=your_key_here

# Option C: LNbits (self-hosted)
# LNBITS_API_KEY=your_invoice_key_here
# LNBITS_URL=https://your-lnbits-instance.com

# ─── Supabase (payment logging + dashboard) ───────────────────────
# Create project at supabase.com, run supabase/schema.sql once
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Managed mode ─────────────────────────────────────────────────
# Your Lightning Address — receives 99.7% of every payment
OWNER_LIGHTNING_ADDRESS=you@blink.sv

# Random secret for split API auth — generate: openssl rand -hex 32
SPLIT_SECRET=your-random-32-char-secret-here

# ShinyDapps backend (leave blank to use production)
# SHINYDAPPS_API_URL=https://shinydapps-api.vercel.appIsInR5cCI6IkpXVCJ9...

# ─── Managed mode ─────────────────────────────────────────────────
# Your Lightning Address — receives 99.7% of every payment
OWNER_LIGHTNING_ADDRESS=you@blink.sv

# Random secret for split API auth — generate: openssl rand -hex 32
SPLIT_SECRET=your-random-32-char-secret-here

# ShinyDapps backend (leave blank to use production)
# SHINYDAPPS_API_URL=https://shinydapps-api.vercel.app

PORT=3000
